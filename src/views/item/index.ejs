<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= name %></title>
  <style>
    h1 {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    img {
      width: 64px;
      height: 64px;
      object-fit: cover;
    }
  </style>
</head>
<body>
  <h1>
    <% if (image) { %>
      <img src="/uploads/<%= image %>.avif" alt="<%= name %>">
    <% } else { %>
      <div style="width:56px; height:56px; display:inline-flex; align-items:center; justify-content:center; font-weight:bold; border: 4px solid #000;">
      <%= name.charAt(0).toUpperCase() %>
      </div>
    <% } %>
    <span><%= name %></span>
  </h1>
  <span><button onclick="vote('<%= id %>', 1, 'item', 'voteText')">upvote</button>/<button onclick="vote('<%= id %>', 0, 'item', 'voteText')">downvote</button></span>
  <span><%= votes.upvotes - votes.downvotes %></span>
	<p id="voteText"></p>
  <span class="tags">
    <% tags.forEach(tag => { %>
      <span id='<%= tag.id %>' class="tag">
        <a href="/list/<%= tag.name %>/top"><%= tag.name %></a>
        <a href="javascript:void(0);" onclick="vote(['<%= id %>', '<%= tag.id %>'], 1, 'tag', 'vote-<%= tag.id %>')">↑</a>
        <a href="javascript:void(0);" onclick="vote(['<%= id %>', '<%= tag.id %>'], 0, 'tag', 'vote-<%= tag.id %>')">↓</a>
        <span id="vote-<%= tag.id %>"></span>
      </span>
    <% }) %> - <a href="tags">all</a></span>
  </span>
	<p><%= desc %></p>
	<a href="/item/<%= name %>/edit">edit</a><br>
	<a href="/">search</a><br>
<script src="/js/vote.js"></script>
</body>
</html>
